import matplotlib.pyplot as plt


def preview(volume):

    z, y, x = volume.shape

    fig, ax = plt.subplots(1, 3, figsize=(15,5))

    #
    # Original B-scan
    #
    ax[0].imshow(volume.intensity[:, y//2, :], cmap="gray")

    ax[0].set_title("B-scan")

    #
    # En-face
    #
    ax[1].imshow(volume.intensity.mean(axis=0), cmap="gray")

    ax[1].set_title("En-face")

    #
    # Orthogonal
    #
    ax[2].imshow(volume.intensity[:, :, x//2], cmap="gray")

    ax[2].set_title("Orthogonal")

    plt.tight_layout()
    plt.show()
